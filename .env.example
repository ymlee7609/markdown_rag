# Markdown RAG Configuration

# Embedding backend: "local" (default, no API key needed) or "openai"
MDRAG_EMBEDDING_BACKEND=local

# Local embedding model (sentence-transformers, multilingual)
MDRAG_LOCAL_MODEL=intfloat/multilingual-e5-small

# OpenAI API key (required only for "openai" embedding or "ask" mode)
OPENAI_API_KEY=

# OpenAI embedding model
MDRAG_OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# LLM backend: "openai" (default) or "local"
MDRAG_LLM_BACKEND=openai

# OpenAI LLM model for RAG answers
MDRAG_OPENAI_LLM_MODEL=gpt-4o-mini

# Local LLM settings (llama-cpp-python, GGUF model)
MDRAG_LOCAL_LLM_MODEL_PATH=
MDRAG_LOCAL_LLM_CONTEXT_SIZE=4096
MDRAG_LOCAL_LLM_MAX_TOKENS=1024

# ChromaDB persistent storage path
MDRAG_CHROMA_PATH=./data/chroma

# ChromaDB collection name
MDRAG_COLLECTION_NAME=markdown_docs

# Chunk settings
MDRAG_CHUNK_MAX_SIZE=1000
MDRAG_CHUNK_OVERLAP=100

# Search settings
MDRAG_SEARCH_TOP_K=5
MDRAG_SEARCH_MODE=vector
MDRAG_HYBRID_ALPHA=0.7
MDRAG_BM25_INDEX_PATH=./data/bm25_index.pkl

# Reranking settings
MDRAG_RERANK_ENABLED=false
MDRAG_RERANK_MODEL=BAAI/bge-reranker-v2-m3
MDRAG_INITIAL_TOP_K=20

# API server
MDRAG_API_HOST=0.0.0.0
MDRAG_API_PORT=8900
